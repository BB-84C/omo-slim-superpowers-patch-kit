diff --git a/src/utils/system-collapse.test.ts b/src/utils/system-collapse.test.ts
new file mode 100644
index 0000000..8f17067
--- /dev/null
+++ b/src/utils/system-collapse.test.ts
@@ -0,0 +1,20 @@
+import { describe, expect, test } from 'bun:test';
+import { collapseSystemInPlace } from './system-collapse';
+
+describe('collapseSystemInPlace', () => {
+  test('joins multiple system messages in place', () => {
+    const system = ['alpha', 'beta'];
+
+    collapseSystemInPlace(system);
+
+    expect(system).toEqual(['alpha\n\nbeta']);
+  });
+
+  test('removes empty system messages', () => {
+    const system = ['', ''];
+
+    collapseSystemInPlace(system);
+
+    expect(system).toEqual([]);
+  });
+});
diff --git a/src/utils/system-collapse.ts b/src/utils/system-collapse.ts
new file mode 100644
index 0000000..edf1514
--- /dev/null
+++ b/src/utils/system-collapse.ts
@@ -0,0 +1,7 @@
+/**
+ * Collapse a mutable system-message array to a single provider-safe entry.
+ */
+export function collapseSystemInPlace(system: string[]): void {
+  const joined = system.filter(Boolean).join('\n\n');
+  system.splice(0, system.length, ...(joined ? [joined] : []));
+}
