-function checkConfigFile(
-  scope: 'user' | 'project',
-  configPath: string | null,
-): ConfigCheckResult {
-  if (configPath === null) {
-    return { scope, path: null, exists: false, ok: true };
-  }
-
-  try {
-    const stat = fs.statSync(configPath);
-
-    if (stat.size === 0) {
-      return {
-        scope,
-        path: configPath,
-        exists: true,
-        ok: false,
-        error: {
-          kind: 'invalid-json',
-          message: 'Empty file is not valid JSON',
-        },
-      };
-    }
