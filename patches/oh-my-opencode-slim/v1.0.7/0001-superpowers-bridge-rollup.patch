+      expect(store.snapshot()['anthropic/claude-opus-4-7']).toBeUndefined();
+    } finally {
+      cleanup();
+    }
+  });
+
+  test('getCooldownStore exposes the underlying store', () => {
+    const { mgr, store, cleanup } = makeManagerWithStore();
+    try {
